# Personal data — never commit. Users bring their own.
pm_holdings.json
crh_ledger.json
*.db
*.sqlite
*.sqlite3
data/

# Secrets
.env
.env.local

# Build output. web/dist is a build artifact — `make ui` / `make build`
# regenerates it; only the .gitkeep placeholder is committed so `go:embed
# all:dist` always has a directory to embed. A bare `go build` without the UI
# build produces a binary that serves an empty UI — use make.
node_modules/
web/dist/*
!web/dist/.gitkeep
/coinrollhunter
/coinrollhunter.exe
/dist/

# Python
__pycache__/
*.pyc
.venv/

# OS / editor
.DS_Store
Thumbs.db
*.xlsx
.idea/
.vscode/
