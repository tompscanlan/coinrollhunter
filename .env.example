# Spot price provider for background polling (ADR-007). The default provider
# (gold-api) is keyless, so polling works out of the box. Set to "none" (or
# "manual"/"off") to disable polling and use manual entry only.
CRH_SPOT_PROVIDER=gold-api
# Poll cadence (Go duration, e.g. 6h, 90m). Default 6h.
CRH_SPOT_INTERVAL=6h
# API key for a keyed provider (not needed for the keyless default). Never commit a real key.
CRH_SPOT_API_KEY=
# Port the local app serves on
PORT=8765
